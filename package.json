{
  "name": "es-file-traverse",
  "version": "2.0.1",
  "type": "module",
  "exports": "./src/index.js",
  "main": "./src/index.js",
  "bin": {
    "es-file-traverse": "./bin/cli.js"
  },
  "description": "Facilities for traversing JavaScript files",
  "author": "Brett Zamir",
  "contributors": [],
  "scripts": {
    "prepublishOnly": "echo \"Don't use pnpm as resolve appears to break\" && npm run license-badges",
    "license-badge": "license-badger --corrections --uncategorizedLicenseTemplate \"\\${license} (\\${name} (\\${version}))\" --filteredTypes=nonempty --textTemplate \"License types\n(project, deps, and bundled devDeps)\" --packageJson --production badges/licenses-badge.svg",
    "license-badge-dev": "license-badger --corrections --filteredTypes=nonempty --textTemplate \"License types\n(all devDeps)\" --allDevelopment badges/licenses-badge-dev.svg",
    "license-badges": "npm run license-badge && npm run license-badge-dev",
    "build-cli-svg": "clp --format=svg --config=src/optionDefinitions.js doc-includes/cli.svg",
    "build-cli": "npm run build-cli-svg",
    "cli": "node ./bin/cli.js",
    "help": "node ./bin/cli.js --help",
    "version": "node ./bin/cli.js --version",
    "cli-example": "npm run cli -- --file=./test/fixtures/main.js",
    "eslint-badge": "eslint-formatter-badger --eslintCache --outputPath badges/eslint-badge.svg .",
    "eslint-3rdparty-badge": "eslint-formatter-badger --eslintCache --mainTemplate=\"ESLint 3rd party light audit (\\${ruleMapCount} rules against \\${numFiles} files)\" --filteredTypes intrusive,vulnerability --ruleMap .eslintRuleTypeMap.json --outputPath badges/eslint-thirdparty.svg --noEslintInlineConfig --noUseEslintIgnore --noUseEslintrc --eslintConfigPath .eslintrc-3rdparty.js `node ./bin/cli.js --file ./bin/cli.js --node --cjs`",
    "eslint-badges": "npm run eslint-badge && npm run eslint-3rdparty-badge",
    "eslint-3rdparty": "eslint --cache --no-inline-config --no-ignore --no-eslintrc --config .eslintrc-3rdparty.cjs `node ./bin/cli.js --file ./bin/cli.js --node --cjs --ignoreResolutionErrors`",
    "eslint": "eslint --cache --ext=js,md,html .",
    "lint": "npm run eslint",
    "coverage-badge": "coveradge badges/coverage-badge.svg",
    "mocha": "mocha",
    "c8": "echo 'Removing cache which seems to blank out istanbul coverage when breaking out early' && rm -Rf node_modules/.cache && c8 npm run mocha && npm run coverage-badge",
    "test": "npm run eslint && npm run c8"
  },
  "engines": {
    "node": "^20.11.0 || >=22.16.0"
  },
  "c8": {
    "reporter": [
      "lcov",
      "json-summary",
      "text"
    ]
  },
  "repository": "https://github.com/brettz9/es-file-traverse",
  "license": "MIT",
  "keywords": [
    "eslint",
    "files"
  ],
  "homepage": "https://github.com/brettz9/es-file-traverse",
  "bugs": "https://github.com/brettz9/es-file-traverse/issues",
  "dependencies": {
    "@babel/eslint-parser": "^7.28.5",
    "command-line-basics": "^3.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "esquery": "^1.6.0",
    "file-fetch": "^2.0.1",
    "find-package-json": "^1.2.0",
    "globby": "^16.0.0",
    "htmlparser2": "^10.0.0",
    "is-builtin-module": "^5.0.0",
    "resolve": "^1.22.11",
    "resolve.exports": "^2.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/plugin-syntax-top-level-await": "^7.14.5",
    "@fintechstudios/eslint-plugin-chai-as-promised": "^3.1.0",
    "@rvagg/chai-as-promised": "^8.0.2",
    "@typescript-eslint/parser": "^8.47.0",
    "c8": "^10.1.3",
    "chai": "^6.2.1",
    "command-line-publish": "^1.1.0",
    "coveradge": "^0.8.2",
    "eslint": "^9.39.1",
    "eslint-config-ash-nazg": "^39.8.0",
    "eslint-formatter-badger": "^0.10.0",
    "license-badger": "^0.22.1",
    "mocha": "^11.7.5",
    "mocha-badge-generator": "^0.11.0",
    "mocha-multi-reporters": "^1.5.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
